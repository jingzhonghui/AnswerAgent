# LLM 提供商选择：openai | anthropic
LLM_PROVIDER=openai

# 默认模型配置（OpenAI 或兼容 API）
API_KEY=sk-xxx
BASE_URL=
MODEL=gpt-4o

# Anthropic 默认模型（切换 LLM_PROVIDER=anthropic 时也使用 API_KEY/BASE_URL/MODEL 字段）

# 路径配置
KNOWLEDGE_PATH=./knowledge
DATA_PATH=./data/conversations

# 对话历史保留轮数（每轮 = 1问1答），默认 10，可调整
HISTORY_WINDOW=10

# JWT 认证配置
JWT_SECRET_KEY=your-secret-key-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# 默认管理员配置（首次启动时自动创建）
ADMIN_DEFAULT_PASSWORD=admin123

# 深度思考（推理模型）配置
# 深度思考模型使用独立的 provider、api_key、base_url 配置，
# 可以与默认模型完全不同（例如默认用 OpenAI，深度思考用 Anthropic）
# DEEP_MODEL_ENABLED=true
# 推理模型 provider：openai | anthropic（空则复用 LLM_PROVIDER）
# DEEP_LLM_PROVIDER=anthropic
# 推理模型 API key（独立配置，空则复用 API_KEY）
# DEEP_API_KEY=sk-ant-xxx
# 推理模型 base_url（可选，空则复用 BASE_URL）
# DEEP_BASE_URL=
# 推理模型名
# DEEP_MODEL=claude-sonnet-4-20250514
# 推理模型温度（通常更低）
# DEEP_TEMPERATURE=0.1