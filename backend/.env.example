# LLM 提供商选择：openai | anthropic
LLM_PROVIDER=openai

# OpenAI 配置
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o

# Anthropic 配置
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# 路径配置
KNOWLEDGE_PATH=./knowledge
DATA_PATH=./data/conversations

# 对话历史保留轮数（每轮 = 1问1答），默认 10，可调整
HISTORY_WINDOW=10
