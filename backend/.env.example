# ============================================================
# 此文件仅供参考 —— 所有配置已迁移到数据库管理
# ============================================================
#
# 配置现在通过管理后台（/admin）的"模型配置"页面进行管理，
# 存储在 SQLite 数据库的 model_config 表中。
#
# 启动时如果数据库中无配置记录，将使用代码中的硬编码默认值。
# 首次启动后请登录管理后台进行配置。
#
# 敏感配置（JWT 密钥、管理员密码）不出现在管理界面中，
# 如需修改请直接操作数据库。
#
# 以下为各配置项的默认值参考：
#
# LLM_PROVIDER=openai
# API_KEY=
# BASE_URL=
# MODEL=gpt-4o
# KNOWLEDGE_PATH=./knowledge
# DATA_PATH=./data/conversations
# HISTORY_WINDOW=10
# JWT_SECRET_KEY=change-me-in-production
# JWT_ALGORITHM=HS256
# JWT_EXPIRE_MINUTES=1440
# ADMIN_DEFAULT_PASSWORD=admin123
# DEEP_MODEL_ENABLED=true
# DEEP_LLM_PROVIDER=
# DEEP_API_KEY=
# DEEP_BASE_URL=
# DEEP_MODEL=o1-mini
# DEEP_TEMPERATURE=0.1
